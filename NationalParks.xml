<?xml version="1.0" encoding="utf-8" ?> 
<!-- tutorial on how to write an xml file https://www.w3schools.com/xml/xml_syntax.asp, also used examples in A4 document as reference-->
<!-- root element will be National Parks, which is the parent of all other elements-->
<NationalParks xmlns="https://ghibli-codes.github.io/cse445_a4/NationalParks.xml" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="https://ghibli-codes.github.io/cse445_a4/ NationalParks.xsd">
	<!-- the national parks will have 11 children of type national park-->
	<!--each national park has the optional attribute of rating, source on how to format attributes in xml https://www.w3schools.com/xml/xml_attributes.asp-->
	<NationalPark rating = "4.9">
		<!--the child elements will contain name, phone, and address-->
		<Name>Grand Canyon</Name>
		<!-- phone is allowed multiple values, define them using this syntax  https://stackoverflow.com/questions/27745014/how-to-specify-repeated-elements-in-xsd -->
		<PhoneNumbers>928-638-7496</PhoneNumbers>
		<PhoneNumbers>888-297-2757</PhoneNumbers>
		<PhoneNumbers>866-499-2574</PhoneNumbers>
		<!-- address has the elements number, street, city, state, zip and the attribute nearest airport-->
		<Address NearestAirport= "Flagstaff">
			<Number>8</Number>
			<Street>S Entrance Road</Street>
			<City>Grand Canyon</City>
			<State>AZ</State>
			<Zip>86023</Zip>
		</Address>
		</NationalPark>
