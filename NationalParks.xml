<?xml version="1.0" encoding="utf-8" ?> 
<!-- tutorial on how to write an xml file https://www.w3schools.com/xml/xml_syntax.asp, also used examples in A4 document as reference-->
<!-- root element will be National Parks, which is the parent of all other elements-->
<NationalParks>
	<!-- the national parks will have 11 children of type national park-->
	<NationalPark>
		<!--the child elements will contain name, phone, and address-->
		<Name>Grand Canyon</Name>
		<!-- phone is allowed multiple values, define them using this syntax https://stackoverflow.com/questions/29457518/convention-for-multiple-items-in-an-xml-file-->
		<PhoneNumbers>
			<phone ref = "928-638-7496"/>
			<phone ref = "888-297-2757"/>
			<phone ref = "866-499-2574"/>
		</PhoneNumbers>
		<!-- address has the attributes number, street, city, state, zip and nearest airport-->
		<Address>
			<Number>8</Number>
			<Street>S Entrance Road</Street>
			<City>Grand Canyon</City>
			<State>AZ</State>
			<Zip>86023</Zip>
			<!-- has the required attr of nearest airport-->
			<NearestAirport>Flagstaff</NearestAirport>
		</Address>
		<!-- has the optional attr of rating-->
		<Rating>4.9</Rating>
		</NationalPark>
